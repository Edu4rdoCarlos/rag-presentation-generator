# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true

# ── Provider selection (optional) ────────────────────────────────────────────
# When LLM_PROVIDER is not set, the provider is auto-detected from the first
# API key found below (priority: openai → anthropic → nvidia → google).
# Uncomment to force a specific provider:
# LLM_PROVIDER=openai

# Override the model name for the active provider (optional):
# LLM_MODEL=gpt-4o

# ── Google / Gemini ───────────────────────────────────────────────────────────
GOOGLE_API_KEY=AIza...
GOOGLE_MODEL=gemini-2.5-flash

# ── OpenAI ────────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Note: Anthropic has no embeddings API. Set GOOGLE_API_KEY or OPENAI_API_KEY
# as fallback for the vector store (RAG).
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── NVIDIA NIM ────────────────────────────────────────────────────────────────
# NVIDIA_API_KEY=nvapi-...
# NVIDIA_MODEL=meta/llama-3.1-70b-instruct
